sw:PromptEngineering a skos:Concept ;
    skos:prefLabel "Prompt Engineering"@en ;
    skos:altLabel "Prompts"@en ;
    skos:altLabel "Prompt Design"@en ;
    skos:definition "The practice of designing effective prompts for AI models"@en .

sw:RAG a skos:Concept ;
    skos:prefLabel "RAG"@en ;
    skos:altLabel "Retrieval Augmented Generation"@en ;
    skos:altLabel "Vector Database"@en ;
    skos:definition "Retrieval-augmented generation for AI applications"@en .

sw:MachineLearning a skos:Concept ;
    skos:prefLabel "Machine Learning"@en ;
    skos:altLabel "ML"@en ;
    skos:definition "Machine learning algorithms and techniques"@en .

sw:Embedding a skos:Concept ;
