@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sw: <http://soypete.tech/twitch/topics/> .

# SKOS Thesaurus for Twitch Stream Topics
# Extends L2WS ontology for stream-specific topics

# --- Core Software Topics (from L2WS) ---

sw:Go a skos:Concept ;
    skos:prefLabel "Go"@en ;
    skos:altLabel "Golang"@en ;
    skos:altLabel "Gopher"@en ;
    skos:definition "The Go programming language, also known as Golang"@en .

sw:Python a skos:Concept ;
    skos:prefLabel "Python"@en ;
    skos:altLabel "Python3"@en ;
    skos:definition "The Python programming language"@en .

sw:Rust a skos:Concept ;
    skos:prefLabel "Rust"@en ;
    skos:altLabel "Rustlang"@en ;
    skos:definition "The Rust programming language"@en .

sw:JavaScript a skos:Concept ;
    skos:prefLabel "JavaScript"@en ;
    skos:altLabel "JS"@en ;
    skos:altLabel "Node.js"@en ;
    skos:definition "The JavaScript programming language and Node.js runtime"@en .

sw:TypeScript a skos:Concept ;
    skos:prefLabel "TypeScript"@en ;
    skos:altLabel "TS"@en ;
    skos:definition "The TypeScript programming language"@en .

